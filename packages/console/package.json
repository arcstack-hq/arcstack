{
    "name": "@arcstack-hq/console",
    "version": "0.1.3",
    "type": "module",
    "description": "Console package for Arcstack providing console-specific implementations of core Arcstack features such as routing, middleware, and database integration.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arcstack-hq/arcstack.git",
        "directory": "packages/console"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "arch": "./dist/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./app": {
            "types": "./dist/app.d.ts",
            "import": "./dist/app.js"
        }
    },
    "peerDependencies": {
        "clear-router": "^2.1.6"
    },
    "dependencies": {
        "@arcstack-hq/common": "workspace:^",
        "@arcstack-hq/contract": "workspace:^",
        "@h3ravel/musket": "^0.10.1",
        "chalk": "^5.6.2",
        "resora": "^0.2.3"
    }
}
