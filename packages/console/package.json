{
    "name": "@arkstack/console",
    "version": "0.1.12",
    "type": "module",
    "description": "Console package for Arkstack providing console-specific implementations of core Arkstack features such as routing, middleware, and database integration.",
    "homepage": "https://arkstack.toneflix.net",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arkstack-hq/arkstack.git",
        "directory": "packages/console"
    },
    "keywords": [
        "console",
        "cli",
        "command-line",
        "interface",
        "runtime",
        "application",
        "framework",
        "stubs",
        "musket",
        "h3ravel"
    ],
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest",
        "version:patch": "pnpm version patch",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "ark": "./dist/index.js",
        "prepare": "./dist/prepare.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./app": {
            "types": "./dist/app.d.ts",
            "import": "./dist/app.js"
        }
    },
    "peerDependencies": {
        "clear-router": "^2.1.7",
        "arkormx": "^0.2.1"
    },
    "dependencies": {
        "@arkstack/common": "workspace:^",
        "@arkstack/contract": "workspace:^",
        "@h3ravel/musket": "^0.10.1",
        "chalk": "^5.6.2",
        "resora": "^0.2.6"
    }
}
