{
    "name": "@arcstack-hq/contract",
    "version": "0.1.4",
    "type": "module",
    "description": "Contract package for Arcstack providing contract-specific implementations of core Arcstack features such as routing, middleware, and database integration.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arcstack-hq/arcstack.git",
        "directory": "packages/contract"
    },
    "keywords": [
        "contract",
        "interface",
        "types",
        "validation",
        "schema",
        "arcstack"
    ],
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    }
}
