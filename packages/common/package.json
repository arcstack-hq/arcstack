{
    "name": "@arcstack-hq/common",
    "version": "0.1.3",
    "type": "module",
    "description": "Common package for Arcstack providing common implementations of core Arcstack features such as routing, middleware, and database integration.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arcstack-hq/arcstack.git",
        "directory": "packages/common"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown --config-loader unconfig",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "dependencies": {
        "detect-port": "^2.1.0"
    }
}
