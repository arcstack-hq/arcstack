{
    "name": "@arcstack-hq/driver-express",
    "version": "0.1.3",
    "type": "module",
    "description": "Express driver package for Arcstack providing Express-specific implementations of core Arcstack features such as routing, middleware, and database integration.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arcstack-hq/arcstack.git",
        "directory": "packages/driver-express"
    },
    "files": [
        "dist",
        "stubs"
    ],
    "scripts": {
        "build": "tsdown",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@arcstack-hq/contract": "workspace:^"
    },
    "peerDependencies": {
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6"
    }
}
