{
    "name": "@arkstack/database",
    "version": "0.1.0",
    "type": "module",
    "description": "Database package for Arkstack providing database-specific implementations of core Arkstack features such as routing, middleware, and database integration.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arkstack/arkstack.git",
        "directory": "packages/database"
    },
    "keywords": [
        "database",
        "integration",
        "client",
        "connection",
        "query",
        "execution",
        "arkstack",
        "prisma",
        "typeorm",
        "mongoose",
        "sequelize"
    ],
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown --config-loader unconfig",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    }
}