    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@arcstack-hq/contract": "workspace:^"
    },
    "peerDependencies": {
        "clear-router": "^2.1.6",
        "h3": "2.0.1-rc.14"
    }
