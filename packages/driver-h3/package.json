{
    "name": "@arkstack/driver-h3",
    "version": "0.1.3",
    "type": "module",
    "private": true,
    "description": "H3 driver package for Arkstack providing H3-specific implementations of core Arkstack features such as routing, middleware, and database integration.",
    "homepage": "https://arkstack.toneflix.net",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arkstack-hq/arkstack.git",
        "directory": "packages/driver-h3"
    },
    "keywords": [
        "h3",
        "driver",
        "integration",
        "routing",
        "middleware",
        "database",
        "arkstack",
        "http",
        "server",
        "rest",
        "api",
        "framework"
    ],
    "files": [
        "dist",
        "stubs"
    ],
    "scripts": {
        "build": "tsdown",
        "version:patch": "pnpm version patch --no-git-tag-version",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@arkstack/contract": "workspace:^"
    },
    "peerDependencies": {
        "clear-router": "^2.1.6",
        "h3": "2.0.1-rc.14"
    }
}
