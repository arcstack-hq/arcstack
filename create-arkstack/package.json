{
  "name": "create-arkstack",
  "type": "module",
  "version": "0.1.16",
  "description": "Scaffold new H3.js or Express.js applications using Toneflix's arkstack templates and starter kits",
  "homepage": "https://arkstack.toneflix.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkstack-hq/arkstack.git",
    "directory": "create-arkstack"
  },
  "keywords": [
    "toneflix",
    "create-arkstack",
    "h3",
    "express",
    "scaffold",
    "template",
    "starter kit",
    "cli",
    "generator",
    "boilerplate",
    "project setup",
    "node.js",
    "javascript",
    "typescript",
    "web development",
    "full-stack",
    "backend",
    "framework",
    "web server",
    "api",
    "microservices",
    "serverless",
    "cloud",
    "dev tools",
    "productivity",
    "arkstack"
  ],
  "main": "build/index.js",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-arkstack": "bin/run.js"
  },
  "exports": {
    ".": "./bin/run.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "runner": "tsx --experimental-specifier-resolution=node src/run.ts",
    "build": "tsdown",
    "version": "pnpm run build",
    "unlink": "npm unlink -g create-arkstack",
    "release": "pnpm build && pnpm changeset version && pnpm changeset publish",
    "publish-it": "pnpm build && pnpm publish --tag latest",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "bin",
    "bin/run.d.ts",
    "bin/run.js"
  ],
  "dependencies": {
    "@antfu/install-pkg": "1.1.0",
    "@h3ravel/collect.js": "^5.3.4",
    "@h3ravel/musket": "^0.10.1",
    "@h3ravel/shared": "^0.28.4",
    "@h3ravel/support": "^0.16.1",
    "@inquirer/core": "^10.2.2",
    "giget": "^2.0.0",
    "inquirer": "^12.9.6",
    "ora": "^9.0.0",
    "tsdown": "^0.15.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "eslint": "^9.32.0",
    "ts-node": "^10.9.2"
  },
  "packageManager": "pnpm@10.14.0"
}